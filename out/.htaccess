# ─── BM klus BV — Apache redirects & security ────────────────────────────────
# Generated for static Next.js export on OneHome/Antagonist (Apache)
# All 301 redirects from old WordPress site → new static site

RewriteEngine On

# ─── Force HTTPS ──────────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── Remove www (canonical: bm-klus-bv.nl without www) ───────────────────────
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# ─── 301 Redirects: changed URLs ─────────────────────────────────────────────
Redirect 301 /over_ons/ /over-ons/
Redirect 301 /muren-stucen-2/ /muren-stucen/
Redirect 301 /buitenstucwerk-woning-halsteren-sierpleister-schilderwerk-2025/ /onze-werken/halsteren-buitenstucwerk-sierpleister-schilderwerk-2025/

# ─── 301 Redirects: project pages (old WP → new /onze-werken/) ───────────────
# These redirect to /onze-werken/ until individual pages are built.
# When a project page is created, update the target to the exact URL.
Redirect 301 /gevelisolatie-woning-rottekade-10cm-schilderwerk-2024/ /onze-werken/
Redirect 301 /vlaardingen-gevelisolatie-6cm-sierpleister-15mm/ /onze-werken/
Redirect 301 /gevelisolatie-vrijstaande-woning-nieuw-beijerland-zuidzijdsedijk/ /onze-werken/
Redirect 301 /gevelisolatie-woning-bruinisse-6cm-sierpleister/ /onze-werken/
Redirect 301 /gevelisolatie-woning-dordrecht-10cm-sierpleister/ /onze-werken/
Redirect 301 /gevelisolatie-woning-klaaswaal-6cm-sierpleister/ /onze-werken/
Redirect 301 /buitenstucwerk-woning-rotterdam-cementpleister/ /onze-werken/
Redirect 301 /gevelisolatie-woning-almere-35m2-sierpleister/ /onze-werken/
Redirect 301 /gevelisolatie-woning-vlaardingen-10cm-sierpleister/ /onze-werken/
Redirect 301 /vught-gevelisolatie-10cm-sierpleister/ /onze-werken/
Redirect 301 /gevelisolatie-woning-katwijk-6cm-sierpleister/ /onze-werken/

# ─── 301 Redirects: old /object* pages (image-only, no content) ──────────────
Redirect 301 /object1/ /onze-werken/
Redirect 301 /object2/ /onze-werken/
Redirect 301 /object3/ /onze-werken/
Redirect 301 /object4/ /onze-werken/
Redirect 301 /object5/ /onze-werken/
Redirect 301 /object6/ /onze-werken/
Redirect 301 /object7/ /onze-werken/
Redirect 301 /object8/ /onze-werken/
Redirect 301 /object9/ /onze-werken/
Redirect 301 /object10/ /onze-werken/
Redirect 301 /object-11/ /onze-werken/
Redirect 301 /object12/ /onze-werken/
Redirect 301 /object13/ /onze-werken/
Redirect 301 /object14/ /onze-werken/
Redirect 301 /object15/ /onze-werken/

# ─── 301 Redirect: removed service ───────────────────────────────────────────
Redirect 301 /schoonmaak-na-verbouwing/ /diensten/

# ─── Block WordPress artifacts ───────────────────────────────────────────────
# Return 410 Gone for WP paths (tells Google to deindex)
RewriteRule ^wp-admin(/|$) - [G,L]
RewriteRule ^wp-includes(/|$) - [G,L]
RewriteRule ^wp-content(/|$) - [G,L]
RewriteRule ^wp-login\.php$ - [G,L]
RewriteRule ^xmlrpc\.php$ - [G,L]
RewriteRule ^wp-json(/|$) - [G,L]

# Block old Rank Math sitemap artifacts
RewriteRule ^main-sitemap\.xsl$ - [G,L]
RewriteRule ^page-sitemap\.xml$ - [G,L]

# ─── Custom 404 ──────────────────────────────────────────────────────────────
ErrorDocument 404 /404.html

# ─── Security headers ────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ─── Cache static assets ─────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 0 seconds"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ─── Gzip compression ────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
